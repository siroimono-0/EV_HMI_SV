/* USER CODE BEGIN 4 */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART1)
  {
    // 1바이트 수신됨 (u8_rx)
    modbus_buf[st_len++] = u8_rx;

    // 타이머값 초기화
    __HAL_TIM_SET_COUNTER(&htim2, 0);
    // 타이머 재시작
    HAL_TIM_Base_Start_IT(&htim2);

    // 다시 인터럽트 대기
    HAL_UART_Receive_IT(&huart1, &u8_rx, 1);
  }
}

// 타이머 타임아웃 시 호출댐
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
  if (htim->Instance == TIM2)
  {
    // 타이머 종료 함수
    HAL_TIM_Base_Stop_IT(&htim2);
    // main에서 버퍼 확인하고 응답보냄
    frame_done = 1;
  }
  else if (htim->Instance == TIM3)
  {
    HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
    HR_value_update();
    // HR_value_update_flag = 1;
  }
  //	  HAL_TIM_Base_Start_IT(&htim2);
}

void HR_value_init()
{
  holding_reg_read_stat[0] = STATE_IDLE;
  holding_reg_read_stat[1] = FAULT_NONE;

  holding_reg_read_stat[2] = voltage;
  holding_reg_read_stat[3] = current;

  // 초기화
  Battery_current = 14400; // (Wh);
  Battery_full = 72000;    // (Wh);

  holding_reg_read_stat[4] = (Battery_current >> 16) & 0xFFFF;
  holding_reg_read_stat[5] = (Battery_current) & 0xFFFF;
  holding_reg_read_stat[6] = (Battery_full >> 16) & 0xFFFF;
  holding_reg_read_stat[7] = (Battery_full) & 0xFFFF;

  return;
}

void HR_value_update()
{
  holding_reg_read_stat[0] = STATE_CHARGING;
  holding_reg_read_stat[1] = FAULT_NONE;

  Battery_current += ((uint32_t)(voltage * current) / 3600);

  // holding_reg_read_stat[12] = (Battery_current / Battery_full);
  holding_reg_read_stat[4] = (Battery_current >> 16) & 0xFFFF;
  holding_reg_read_stat[5] = (Battery_current) & 0xFFFF;
  return;
}

void modbus_pasing()
{
  frame_done = 0;

  uint8_t tmp_buf[256];
  uint16_t tmp_len = 0;

  __disable_irq();
  tmp_len = st_len;
  if (tmp_len > sizeof(tmp_buf))
  {
    tmp_len = sizeof(tmp_buf);
  }
  for (int i = 0; i < tmp_len; i++)
  {
    tmp_buf[i] = modbus_buf[i];
  }
  __enable_irq();

  // 여기서 Modbus 파싱
  if (tmp_len < 4)
  {
    return;
  }

  if (slave_id != tmp_buf[0])
  {
    return;
  }

  if (func_code_start == tmp_buf[1])
  {
    if (tmp_len != 8)
    {
      return;
    }

    uint8_t crc_L = tmp_buf[tmp_len - 2];
    uint8_t crc_H = tmp_buf[tmp_len - 1];
    uint16_t crc_recv = ((uint16_t)crc_H << 8) | (uint16_t)crc_L;

    uint16_t crc_compare = crc_modbus(tmp_buf, tmp_len - 2);
    if (crc_recv != crc_compare)
    {
      return;
    }

    uint16_t reg_addr = ((uint16_t)tmp_buf[2] << 8) | (uint16_t)tmp_buf[3];
    uint16_t reg_val = ((uint16_t)tmp_buf[4] << 8) | (uint16_t)tmp_buf[5];
    // 값 넣어줌
    holding_reg_cmd[reg_addr] = reg_val;

    uint8_t modbus_ack[8];
    for (int i = 0; i < 6; i++)
    {
      modbus_ack[i] = tmp_buf[i];
    }
    uint16_t crc_ack = crc_modbus(modbus_ack, 6);
    modbus_ack[6] = (uint8_t)(crc_ack & 0xFF);
    modbus_ack[7] = (uint8_t)((crc_ack >> 8) & 0xFF);

    // HAL_UART_Transmit(&huart1, modbus_ack, 8, 100);
    HAL_StatusTypeDef e_ret = HAL_UART_Transmit(&huart1, modbus_ack, 8, 100);

    if (e_ret != HAL_OK)
    {
      // 디버깅용: 에러코드 확인
      uint32_t u32_err = HAL_UART_GetError(&huart1);
      // HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);

      // 여기서 브레이크 걸거나 LED 토글/로그 찍어서 확인
      // u32_err는 HAL_UART_ERROR_* 비트로 들어옴
    }
    else
    {
      HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
    }
  }
  else if (func_code_read == tmp_buf[1])
  {
    if (tmp_len != 8)
    {
      return;
    }

    uint8_t crc_L = tmp_buf[tmp_len - 2];
    uint8_t crc_H = tmp_buf[tmp_len - 1];
    uint16_t crc_recv = ((uint16_t)crc_H << 8) | (uint16_t)crc_L;

    uint16_t crc_compare = crc_modbus(tmp_buf, tmp_len - 2);
    if (crc_recv != crc_compare)
    {
      return;
    }
    uint16_t reg_addr = ((uint16_t)tmp_buf[2] << 8) | (uint16_t)tmp_buf[3];
    uint16_t reg_cnt = ((uint16_t)tmp_buf[4] << 8) | (uint16_t)tmp_buf[5];

    uint8_t send_arr[5 + (reg_cnt * 2)];
    size_t send_arr_size = sizeof(send_arr) / sizeof(send_arr[0]);
    send_arr[0] = tmp_buf[0];  // 슬레이브 id
    send_arr[1] = tmp_buf[1];  // func code
    send_arr[2] = reg_cnt * 2; // 데이터 길이

    for (int i = 0; i < reg_cnt; i++)
    {
      uint16_t val_16 = holding_reg_read_stat[reg_addr + i];
      uint8_t val_H = (val_16 >> 8) & 0xFF;
      uint8_t val_L = val_16 & 0xFF;

      send_arr[3 + (2 * i)] = val_H;     // Hi
      send_arr[3 + (2 * i) + 1] = val_L; // Lo
    }

    uint16_t crc_read = crc_modbus(send_arr, send_arr_size - 2);
    uint8_t crc_L_read = crc_read & 0xFF;
    uint8_t crc_H_read = ((uint16_t)crc_read >> 8) & 0xFF;

    send_arr[send_arr_size - 2] = crc_L_read;
    send_arr[send_arr_size - 1] = crc_H_read;

    HAL_UART_Transmit(&huart1, send_arr, send_arr_size, 100);
  }

  st_len = 0; // 다음 프레임 준비
}


