/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART1_UART_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  /* USER CODE BEGIN 2 */

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  //  char send_data[20] = "Hello World\r\n";

  /*
  HAL_UART_Receive_IT()는
  지정한 Size만큼 데이터를 다 받았을 때
  HAL_UART_RxCpltCallback()를 딱 한 번 호출한다.
   */
  HAL_UART_Receive_IT(&huart1, &u8_rx, 1);
  HR_value_init();

  //  타이머 시작 설정
  //  HAL_TIM_Base_Start_IT(&htim2);
  uint8_t ems_state = 0;

  while (1)
  {
	uint8_t ret_ems = HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_0);
	if(ret_ems == 1 && ems_state == 0)
	{
	  ems_state = 1;
	  char test[10] = "ems";
	  HAL_UART_Transmit(&huart1, test, 10, 100);

	  HAL_TIM_Base_Stop_IT(&htim3);
      // read reg값 처음으로 초기화해줌
      // 데모용...
      HR_value_init();
	}
	else if(ret_ems == 0 && ems_state == 1)
	{
		ems_state = 0;
	}
    // HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5); // PA5 토글
    // HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
    // HAL_Delay(1000);
    if (frame_done)
    {
      modbus_pasing();
    }

    if (holding_reg_cmd[START] == 1)
    {
      // 타이머 시작
      // cmd 초기화
      holding_reg_cmd[START] = 0;
      __HAL_TIM_SET_COUNTER(&htim3, 0);
      HAL_TIM_Base_Start_IT(&htim3);
    }
    else if (holding_reg_cmd[STOP] == 1)
    {
      // 타이머 종료
      // cmd 초기화
      holding_reg_cmd[STOP] = 0;
      HAL_TIM_Base_Stop_IT(&htim3);

      // read reg값 처음으로 초기화해줌
      // 데모용...
      HR_value_init();
    }
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

