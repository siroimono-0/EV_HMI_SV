[Unit]
Description=HMI App
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=/home/gray/gray/Qt_project/EV_HMI_SV/Launcher
ExecStart=/home/gray/gray/Qt_project/EV_HMI_SV/Launcher/launcher
Restart=always
RestartSec=1

Environment=QT_QPA_PLATFORM=wayland
Environment=WAYLAND_DISPLAY=wayland-0
Environment=QT_QPA_PLATFORMTHEME=gtk3
Environment=QT_QUICK_CONTROLS_STYLE=Material
Environment=QT_QUICK_CONTROLS_MATERIAL_THEME=Dark

[Install]
WantedBy=default.target
